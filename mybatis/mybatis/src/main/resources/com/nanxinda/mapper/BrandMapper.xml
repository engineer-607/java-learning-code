<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--namespace：名称空间-->
<!--设置SQL映射文件中的namespace属性为Mapper接口全限定名-->
<mapper namespace="com.nanxinda.mapper.BrandMapper">
<!--如果数据库的字段名称和实体类的属性名称不一致，则不能封装成功-->
<!--1.起别名:对不一样的列名起别名，让别名和实体类的属性一样
      缺点：每次查询都要定义一次别名
      可以用sql片段解决这个问题
      但是sql缺点是不够灵活
    2.resultMap
      *定义<resultMap>标签
      *在使用resultMap属性替换resultType属性
-->
    <!--<sql id="brand_column">-->
    <!--    id,brand_name,company_name-->
    <!--</sql>-->
    <!--<select id="selectAll" resultType="brand">-->
    <!--    select id,brand_name as brandName,company_name as companyName from tb_brand;-->
    <!--</select>-->
    <!--<select id="selectAll" resultType="brand">-->
    <!--    select <include refid="brand_column"/> as companyName from tb_brand;-->
    <!--</select>-->
    <!--id:唯一标识-->
    <!--type:映射的类型，支持别名-->
    <resultMap id="brandResultMap" type="brand">
    <!--id标签：完成主键字段的映射-->
    <!--column：完成一般字段的映射-->
        <result column="brand_name" property="brandName"/>
        <result column="company_name" property="companyName"/>
    </resultMap>
<!--添加操作-->
<!--useGeneratedKeys="true" keyProperty="id"用来将数据库中自增的id返回给brand对象-->
    <insert id="add" useGeneratedKeys="true" keyProperty="id">
        insert into tb_brand(brand_name,company_name,ordered,description,status)
        values (#{brandName},#{companyName},#{ordered},#{description},#{status})
    </insert>
<!--    存在的问题：当动态修改数据时，有些数据会被修改为null-->
<!--    <update id="update">-->
<!--        update tb_brand set-->
<!--            brand_name=#{brandName}-->
<!--            company_name=#{companyName}-->
<!--            ordered=#{ordered}-->
<!--            status=#{status}-->
<!--            description=#{description} -->
<!--                        where id = #{id}-->
<!--    </update>-->
    <update id="update">
        update tb_brand
        <set>
            <!--需要使用set标签来替代原本的set，避免下面的字段全为空导致没有语句执行，或者最后一句没有
            执行导致多出一个','造成语法错误-->
            <if test="brandName!=null and brandName==''">
            brand_name=#{brandName},
            </if>
            <if test="companyName!=null and companyName==''">
                company_name=#{companyName},
            </if>
            <if test="ordered!=null">
                ordered=#{ordered},
            </if>
            <if test="status!=null">
                status=#{status},
            </if>
            <if test="description!=null and description!=''">
                description=#{description}
            </if>
    </set>
        where id = #{id}
    </update>
    <delete id="deleteById">
        delete from tb_brand where id = #{id};
    </delete>
<!--mybatis会将数组参数，封装成一个map集合
    默认情况下，key为array，value即为ids数组
-->
    <delete id="deleteByIds">
        delete from tb_brand where id
        in
<!--遍历,collection代表所需要遍历的集合，item表示遍历的元素，separator表示采取的分隔符，open表示开始的内容，close表示结束的内容-->
            <foreach collection="ids" item="id" separator="," open="(" close=")">
                #{id}
            </foreach>

    </delete>
    <select id="selectAll" resultMap="brandResultMap">
        select * from tb_brand;
    </select>
    <!--*参数占位符：-->
    <!--1.#{}:会将其替换为?，为了放置SQL注入
        2.${}:拼sql、会存在SQL注入问题
        3.使用时机：
            * 参数传递的时候:#{}
            * 表名或者列名不固定的情况下:${}
        4.参数类型:parameterType，可以省略
        5.特殊字符的处理:
            *转义字符(比如无法直接打出<可以用转义符:&lt;
            *CDATA区<![CDATA[]]>
        -->
    <select id="selectById" parameterType="int" resultMap="brandResultMap">
        select * from tb_brand where id <![CDATA[
           <
        ]]> #{id};
    </select>
<!--    动态条件查询-->
<!--       *if：条件查询-->
<!--          * test：逻辑表达式-->
<!--    存在的问题：如果第一个条件不满足，而第二个满足，条件表达式where后就会多出一个and-->
<!--    解决方案：1.每个条件都加and，在where后面加恒等式，例如1=1
                2.<where>替换where关键字-->
    <select id="selectByCondition" resultMap="brandResultMap">
        select * from tb_brand
        <where>
          <if test="status!=null">
            status = #{status}
          </if>
          <if test="companyName!=null and companyName!=''">
              and company_name like #{companyName}
          </if>
          <if test="brandName!=null and brandName!=''">
              and brand_name like #{brandName};
          </if>
        </where>
    </select>
    <select id="selectByConditionUsingObject" resultMap="brandResultMap" >
        select * from tb_brand
        where status = #{status}
        and company_name like #{companyName}
        and brand_name like #{brandName};
    </select>
    <select id="selectByConditionUsingMap" resultMap="brandResultMap">
        select * from tb_brand
        where status = #{status}
        and company_name like #{companyName}
        and brand_name like #{brandName};
    </select>
    <select id="selectByConditionSingle" resultMap="brandResultMap">
        select * from tb_brand
        <where>
<!--choose相当switch-->
            <choose>
<!--when相当于case-->
                <when test="status!=null">
                    status = #{status}
                </when>
                <when test="companyName!=null and companyName!=''">
                    company_name like #{companyName}
                </when>
                <when test="brandName!=null and brandName!=''">
                    brand_name like #{brandName}
                </when>
                <!--otherwise相当于default-->
                <otherwise>
                    '1'  = '1'
                </otherwise>
            </choose>
        </where>
    </select>
    <!--条件查询-->


</mapper>